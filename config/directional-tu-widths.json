{
	"method": "directional_tu_widths",
	"crs": {
		"input": "EPSG:4326",
		"metric": "EPSG:31256",
		"pmtiles": "EPSG:4326"
	},
	"paths": {
		"work_dir": "work/directional-tu-widths",
		"output_dir": "dist/directional-tu-widths",
		"surfaces_metric": "work/directional-tu-widths/directional_surfaces_metric.geojsonseq",
		"surfaces_wgs84": "work/directional-tu-widths/directional_surfaces_4326.geojsonseq",
		"pmtiles": "dist/directional-tu-widths/directional_tu_widths.pmtiles",
		"summary": "dist/directional-tu-widths/directional_tu_widths_summary.json"
	},
	"sources": {
		"sis": {
			"name": "SIS Belagsflaechen Testausschnitt",
			"url": "https://tiles.radlobby.at/Gehsteigbreiten/Testdaten/SISBELAGOGD.json",
			"filter_property": "TYPE",
			"filter_values": [
				"GG",
				"EE",
				"HH"
			]
		},
		"centerlines": {
			"name": "Centerlines Testausschnitt",
			"url": "work/directional-tu-widths/generated_centerlines_metric.geojsonseq",
			"crs": "EPSG:31256",
			"enabled": true
		},
		"street_axis": {
			"name": "EDGE_OGD Testausschnitt",
			"url": "https://tiles.radlobby.at/Gehsteigbreiten/Testdaten/Strassengraph.fgb",
			"enabled": true,
			"crs": "EPSG:4326",
			"filter": {
				"baustatus_property": "BAUSTATUS",
				"baustatus_values": [
					5
				],
				"frc_property": "FRC",
				"frc_include": [
					0,
					1,
					2,
					3,
					4,
					5,
					6,
					7,
					8
				],
				"fow_property": "FOW",
				"fow_exclude": [
					14,
					15,
					16,
					18,
					19,
					101,
					102,
					103,
					104,
					504,
					505,
					601,
					701
				]
			}
		},
		"fmzk": {
			"name": "FMZK Gehsteig Testausschnitt",
			"url": "https://tiles.radlobby.at/Gehsteigbreiten/Testdaten/FMZKVERKEHR2OGD.json",
			"filter_property": "LAYER",
			"filter_values": [
				"Gehsteig"
			]
		}
	},
	"preprocess": {
		"make_valid": true,
		"explode_multipart": true,
		"min_area_m2": 0.01
	},
	"direction": {
		"centerline_search_m": 3.0,
		"street_search_m": 25.0,
		"max_width_m": 8.0,
		"min_width_m": 0.2,
		"tangent_delta_m": 2.0,
		"use_directional_width": true
	},
	"width_classes": [
		{
			"id": 0,
			"label": "< 1.2 m",
			"min": null,
			"max": 1.2
		},
		{
			"id": 1,
			"label": ">= 1.2 m - < 1.5 m",
			"min": 1.2,
			"max": 1.5
		},
		{
			"id": 2,
			"label": ">= 1.5 m - < 2.0 m",
			"min": 1.5,
			"max": 2.0
		},
		{
			"id": 3,
			"label": ">= 2.0 m - < 3.0 m",
			"min": 2.0,
			"max": 3.0
		},
		{
			"id": 4,
			"label": ">= 3.0 m",
			"min": 3.0,
			"max": null
		}
	],
	"pmtiles": {
		"layer_name": "directional_surfaces",
		"min_zoom": 12,
		"max_zoom": 17,
		"base_zoom": 14
	},
	"centerline_build": {
		"summary": "dist/directional-tu-widths/generated_centerlines_summary.json",
		"centerline": {
			"make_valid": true,
			"explode_multipart": true,
			"min_area_m2": 0.25,
			"simplify_tolerance_m": 0.05,
			"densify_distance": -1,
			"min_branch_length": -2,
			"simplifytolerance": -0.25,
			"extend": true,
			"min_line_length_m": 1.0,
			"keep_branches": true,
			"merge_connected_lines": true,
			"post_simplify_tolerance_m": 0.25,
			"post_simplify_preserve_topology": false,
			"straighten_nearly_linear": true,
			"straighten_min_length_m": 8.0,
			"straighten_max_deviation_m": 3.0,
			"straighten_max_length_ratio": 2.5,
			"straight_simplify_nearly_linear": true,
			"straight_simplify_tolerance_m": 2.5,
			"straight_simplify_max_hausdorff_m": 3.0,
			"straight_simplify_min_reduction": 2
		}
	}
}
